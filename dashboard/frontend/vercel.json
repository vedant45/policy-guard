{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://chump-kangaroo-blast.ngrok-free.dev/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/ws",
      "destination": "https://chump-kangaroo-blast.ngrok-free.dev/ws"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "ngrok-skip-browser-warning",
          "value": "true"
        }
      ]
    }
  ]
}